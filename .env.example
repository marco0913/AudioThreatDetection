# Required: OpenAI API key for Whisper transcription and LLM threat detection
OPENAI_API_KEY=sk-your-key-here

# Optional: subscriber URL (default: http://localhost:8765/alerts)
SUBSCRIBER_URL=http://localhost:8765/alerts

# Optional: enable GPT-4o audio emotion analysis (bonus path A)
# Adds prosodic signals (anger, urgency, stress) to supplement text-based detection.
# Increases per-turn latency by ~2s but stabilises borderline LLM score variance.
ENABLE_AUDIO_EMOTION=false
